# Normalize line endings to LF on commit, checkout as-is
* text=auto eol=lf

# Force LF for Python, YAML, TOML, Markdown
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.sh    text eol=lf

# Binary — no line-ending conversion
*.png   binary
*.jpg   binary
*.whl   binary
*.tar.gz binary
